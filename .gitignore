# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# pytest
.pytest_cache/

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Artifacts — archived MetricsReport JSON files and experiment configs are committed.
# Large binaries (model weights, exported CoreML bundles) are excluded.
# See artifacts/README.md for the distinction.
artifacts/*
!artifacts/README.md
!artifacts/*.json
!artifacts/eval_task_*/
artifacts/eval_task_*/*
!artifacts/eval_task_*/*.json
!artifacts/clip_scores/
artifacts/clip_scores/*
!artifacts/clip_scores/*.json
!artifacts/clip_preds/
artifacts/clip_preds/*
!artifacts/clip_preds/*.json
!artifacts/experiment_ledger/
artifacts/experiment_ledger/*
!artifacts/experiment_ledger/*.json
artifacts/experiment_ledger/*_preds.json
artifacts/experiment_ledger/*_FAILED.json
!artifacts/device_ready/
artifacts/device_ready/*
!artifacts/device_ready/*.json

# Scratch results directory — working outputs, not committed.
results/

# Dataset photos — only the manifest and our own captions/VQA pairs are committed.
# Users fetch the actual photos from the source datasets (Flickr30k, COCO, Open Images).
datasets/stage_a_proxy/photos/
datasets/stage_a/photos/
datasets/coco_cache/

# Vendored large dependencies — build from source or download separately.
# vendor/VLMEvalKit is committed (small, patched). llama.cpp and ml-fastvlm are not.
vendor/llama.cpp/
vendor/ml-fastvlm/

# Model weight files — never commit these
*.gguf
*.safetensors
*.bin
*.pt
*.pth

# Secrets and local config
.env
*.local

# Xcode user-specific state (should never be committed)
*.xcuserstate
xcuserdata/
